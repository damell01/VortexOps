# ── Database ────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=change_me_strong_password

# ── Site ─────────────────────────────────────────────────────────────────────
# The Frappe site name — typically your domain name
SITE_NAME=app.vortexbreaks.com

# ERPNext Administrator password (first login)
ADMIN_PASSWORD=change_me_admin_password

# ── Network ──────────────────────────────────────────────────────────────────
HTTP_PORT=80

# ── Production / SSL (only needed with docker-compose.prod.yml) ──────────────
DOMAIN=app.vortexbreaks.com
CERTBOT_EMAIL=admin@vortexbreaks.com

# ── Backups (optional — leave blank to keep local-only backups) ───────────────
# S3-compatible bucket name (AWS S3, Backblaze B2, Cloudflare R2)
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=vortex-backups

# AWS / Backblaze / R2 credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Override endpoint for non-AWS S3 (e.g. Backblaze B2):
# AWS_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com

# ── Build ────────────────────────────────────────────────────────────────────
# Pin a specific branch of the vortex_ops repo
# VORTEX_BRANCH=main

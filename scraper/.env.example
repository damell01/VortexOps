# VortexOps API
VORTEXOPS_URL=http://localhost:8000
VORTEXOPS_API_TOKEN=your-scraper-api-token-here

# Whatnot credentials
WHATNOT_EMAIL=your@email.com
WHATNOT_PASSWORD=yourpassword

# Whatnot channel username (the seller account to watch)
WHATNOT_SELLER_USERNAME=vortexbreaks

# How often to check for new shows (milliseconds). Default: 15 minutes
POLL_INTERVAL_MS=900000

# Optional: comma-separated streamer IDs to auto-assign when scraper can't determine
DEFAULT_STREAMER_IDS=

# Headless mode (true = no browser window, false = show browser for debugging)
HEADLESS=true
